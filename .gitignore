# Godot 4+ specific ignores
.godot/
/android/
*.translation

# Imported translations (automatically generated from CSV files)
*.translation

# Mono / C# (if added later)
.mono/
data_*/
mono_crash.*.json

# Godot export presets (often contain credentials/keystores)
export_presets.cfg
.export/
build/
exports/
*.pck
*.zip
*.apk
*.aab
*.ipa
*.exe
*.dmg
*.app/

# Godot editor user data
*.import.tmp

# Save files / user data (game writes to user://save_game.dat)
user://
*.save
*.dat
save_game.dat

# Test output / logs
test-results/
*.log
logs/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.fseventsd
.TemporaryItems

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# Editors / IDEs
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/
nbproject/
*.sublime-project
*.sublime-workspace

# Claude Code local settings (keep shared config, ignore local overrides)
.claude/settings.local.json
.claude/.credentials.json

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
*.key
*.keystore
*.jks
secrets/

# Backup / temp files
*.bak
*.tmp
*.temp
*.orig
*.rej
*~
\#*\#
.#*

# Compiled / generated
*.o
*.obj
*.so
*.dylib
*.dll
*.class
*.pyc
__pycache__/

# Node (if any tooling is added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
